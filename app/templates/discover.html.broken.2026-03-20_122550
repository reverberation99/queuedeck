        const compositeScore = (typeof item.composite_score === "number")
          ? Number(item.composite_score).toFixed(2)
          : "";
        const hiddenGemScore = (typeof item.hidden_gem_score === "number")
          ? Number(item.hidden_gem_score).toFixed(2)
          : "";
        const scoreNum = Number(item.composite_score || 0);

        const letterboxdFeedCount = letterboxdLabels.length;
        const effectiveSourceHits = Math.max(providerHits, letterboxdFeedCount);

        const breakdown = item.score_breakdown || {};
        const hotThresholdNum = Number(breakdown.hot_threshold || 0.82);
        const risingThresholdNum = Math.max(0, hotThresholdNum - 0.12);

        const providerScores = item.provider_scores || {};
        const breakdownScores = breakdown.provider_scores || {};

        const animeHotBySources =
          (
            providerScores.anilist_anime !== undefined &&
            providerScores.jikan_anime_hot !== undefined
          ) ||
          (
            providerScores.jikan_anime_hot !== undefined &&
            providerScores.jikan_anime_rising !== undefined
          );

        const animeRisingBySources =
          providerScores.jikan_anime_rising !== undefined &&
          (
            providerScores.anilist_anime !== undefined ||
            providerScores.jikan_anime_hot !== undefined
          );

        const isSpecialHot =
          animeHotBySources ||
          (effectiveSourceHits >= 2 && scoreNum >= hotThresholdNum);

        const isRising =
          (!isSpecialHot) &&
          (
            animeRisingBySources ||
            (effectiveSourceHits >= 2 && scoreNum >= risingThresholdNum)
          );

        const isHiddenGem = mode === "hidden_gems" && Number(item.hidden_gem_score || 0) >= 0.35;
        const hasTmdbId = !!item.tmdb_id;
        const openUrl = hasTmdbId
          ? `https://www.themoviedb.org/${item.media_type === "movie" ? "movie" : "tv"}/${item.tmdb_id}`
          : String(item.external_url || "#");
        const openLabel = hasTmdbId ? "Open TMDb" : "Open Source";

        const sourceBadges = [];
        let sourceSummary = source;
        const parts = [];

        if (providerScores.tmdb_trending !== undefined || providerScores.tmdb_popular !== undefined) {
          sourceBadges.push('<span class="sourceBadge tmdb">TMDb</span>');
          parts.push("TMDb");
        }

        if (providerScores.trakt_trending !== undefined || providerScores.trakt_popular !== undefined) {
