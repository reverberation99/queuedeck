  <script>
    const discoverGrid = document.getElementById("discoverGrid");
    const discoverStatus = document.getElementById("discoverStatus");
    const discoverIsAdmin = {{ "true" if current_user and current_user.get("is_admin") else "false" }};
    const discoverSource = document.getElementById("discoverSource");
    let QD_FOR_YOU_PROFILE = null;
    const discoverMedia = document.getElementById("discoverMedia");
    const discoverConsensus = document.getElementById("discoverConsensus");
    const discoverGenre = document.getElementById("discoverGenre");
    const discoverSort = document.getElementById("discoverSort");
    const discoverMode = document.getElementById("discoverMode");
    const discoverAdvancedToggle = document.getElementById("discoverAdvancedToggle");
    const discoverAdvancedPanel = document.getElementById("discoverAdvancedPanel");
    const discoverYearFrom = document.getElementById("discoverYearFrom");
    const discoverYearTo = document.getElementById("discoverYearTo");
    const discoverProvider = document.getElementById("discoverProvider");
    const discoverMinRating = document.getElementById("discoverMinRating");
    const discoverReloadBtn = document.getElementById("discoverReloadBtn");
    const discoverLoadMoreBtn = document.getElementById("discoverLoadMoreBtn");
    const discoverBackToTopBtn = document.getElementById("discoverBackToTopBtn");

    const qdAniListGenres = [
      "Action",
      "Adventure",
      "Comedy",
      "Drama",
      "Ecchi",
      "Fantasy",
      "Horror",
      "Mahou Shoujo",
      "Mecha",
      "Music",
      "Mystery",
      "Psychological",
      "Romance",
      "Sci-Fi",
      "Slice of Life",
      "Sports",
      "Supernatural",
      "Thriller"
    ];

    let qdDefaultGenreOptions = "";

    function qdSetGenreOptionsForSource(){
      if (!discoverSource || !discoverGenre) return;

      const src = String(discoverSource.value || "");
      const isAniList =
        src === "anime_aggregate" ||
        src === "anilist_trending" ||
        src === "anilist_popular" ||
        src === "anilist_genre" ||
        src === "jikan_anime_hot" ||
        src === "jikan_anime_rising";

      if (!qdDefaultGenreOptions){
        qdDefaultGenreOptions = discoverGenre.innerHTML;
      }

      if (isAniList){
        const current = String(discoverGenre.value || "all");
        discoverGenre.innerHTML =
          '<option value="all">All</option>' +
          qdAniListGenres.map(g => `<option value="${esc(g)}">${esc(g)}</option>`).join("");

        if (src === "anilist_genre" && qdAniListGenres.includes(current)){
          discoverGenre.value = current;
        } else {
          discoverGenre.value = "all";
        }

