    async function qdFilterForYouOwnedRequested(items){
      const rows = Array.isArray(items) ? items : [];
      if (!rows.length) return rows;

      try{
        const r = await fetch("/api/discover/library-state", {
          method: "POST",
          credentials: "same-origin",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ items: rows })
        });

        const j = await r.json().catch(() => ({}));
        const stateMap = (j && j.items && typeof j.items === "object") ? j.items : {};

        const filtered = rows.filter((item, idx) => {
          const state = stateMap[`row-${idx}`] || {};

          const owned =
            !!state.in_library ||
            !!state.in_sonarr ||
            !!state.in_radarr;

          return !owned;
        });

        return filtered.length ? filtered : rows;
      }catch(e){
        console.warn("For You filter failed", e);
        return rows;
      }
    }

    async function loadDiscover(page=1, append=false){
      const inFlightKey = JSON.stringify({
        page: Number(page || 1),
        append: !!append,
        source: (discoverSource && discoverSource.value) || "",
        media: (discoverMedia && discoverMedia.value) || "",
        genre: (discoverGenre && discoverGenre.value) || "",
        provider: (discoverProvider && discoverProvider.value) || "",
        min_rating: (discoverMinRating && discoverMinRating.value) || "",
        year_from: (discoverYearFrom && discoverYearFrom.value) || "",
        year_to: (discoverYearTo && discoverYearTo.value) || "",
      });

      if (discoverLoadInFlightKey === inFlightKey){
        console.warn("Skipping duplicate discover load", inFlightKey);
        return;
      }

      discoverLoadInFlightKey = inFlightKey;

      const source = discoverSource.value || "tmdb_trending";
      await qdLoadForYouProfile();

      const isAnimeSource =
        source === "anime_aggregate" ||
        source === "anilist_trending" ||
        source === "anilist_popular" ||
        source === "anilist_genre" ||
        source === "jikan_anime_hot" ||
        source === "jikan_anime_rising";

      if (isAnimeSource && discoverMedia && String(discoverMedia.value || "") !== "tv"){
        discoverMedia.value = "tv";
      }

      const media = isAnimeSource ? "tv" : (discoverMedia.value || "all");
      const genre = discoverGenre ? (discoverGenre.value || "all") : "all";
      const provider = discoverProvider ? (discoverProvider.value || "all") : "all";
      const minRating = discoverMinRating ? String(discoverMinRating.value || "").trim() : "";
      const yearFrom = discoverYearFrom ? String(discoverYearFrom.value || "").trim() : "";
      const yearTo = discoverYearTo ? String(discoverYearTo.value || "").trim() : "";

      const requestSeq = ++discoverRequestSeq;
      discoverActiveRequestSeq = requestSeq;

      if (!append){
        discoverPage = 1;
        discoverHasMore = true;
        setStatus("Loading discover data…", "");
        discoverGrid.innerHTML = "";
        if (discoverLoadMoreBtn){
          discoverLoadMoreBtn.style.display = "none";
          discoverLoadMoreBtn.disabled = false;
          discoverLoadMoreBtn.textContent = "Load More";
        }
      } else {
        setStatus("Loading more discover data…", "");
        if (discoverLoadMoreBtn){
          discoverLoadMoreBtn.disabled = true;
          discoverLoadMoreBtn.innerHTML = '<span class="btnSpinner"></span>Loading…';
        }

        // Let the browser paint the button state before the fetch work begins.
        await new Promise(resolve => requestAnimationFrame(() => resolve()));
        await new Promise(resolve => setTimeout(resolve, 0));

        if (discoverLoadMoreTimeout){
          clearTimeout(discoverLoadMoreTimeout);
        }
        discoverLoadMoreTimeout = setTimeout(() => {
          if (discoverLoadMoreBtn){
            discoverLoadMoreBtn.disabled = false;
            discoverLoadMoreBtn.textContent = "Load More";
          }
          setStatus("Load more is taking unusually long. You can try again.", "bad");
        }, 30000);
      }

      try{
        const { r, j } = await fetchDiscoverPayload(page);

        if (requestSeq !== discoverActiveRequestSeq){
          return;
        }

        if (!r.ok || !j.ok){
          const err = j.error || (r.status === 400 ? "Discover source not configured." : ("HTTP " + r.status));
          if (err === "tmdb_not_configured"){
            renderNotConfigured();
            return;
          }
          if (err === "trakt_not_configured"){
            setStatus("Trakt is not configured yet. Add a Trakt Client ID in Preferences.", "bad");
            discoverGrid.innerHTML = "";
            return;
          }
          setStatus("Discover failed: " + err, "bad");
          return;
        }

        let items = j.items || [];
        

        if ((source === "aggregate" || source === "anime_aggregate") && String(discoverSort?.value || "") === "for_you"){
          items = await qdFilterForYouOwnedRequested(items);
          
        }
          j.items = items;

        const genreCounts = {};
        for (const i of items){
          const ids1 = Array.isArray(i.genre_ids) ? i.genre_ids.map(x => String(x)) : [];
          const ids2 = Array.isArray(i.genres)
            ? i.genres
                .map(g => (g && typeof g === "object" && g.id != null) ? String(g.id) : null)
                .filter(Boolean)
            : [];
          const gids = [...new Set([...ids1, ...ids2])];
          for (const g of gids){
            genreCounts[g] = (genreCounts[g] || 0) + 1;
          }
        }
        

        if (requestSeq !== discoverActiveRequestSeq){
          return;
        }

        discoverHasMore = Array.isArray(items) && items.length > 0;
        discoverPage = page;

        if (discoverHasMore){
          const nextPage = Number(page || 1) + 1;
          prefetchDiscoverPage(nextPage);

          if (!append && nextPage === 2 && (source === "anime_aggregate" || source === "aggregate" || source.startsWith("letterboxd_"))){
            setTimeout(() => prefetchDiscoverPage(nextPage), 250);
          }
        }

        renderItems(items, append);

        if (discoverLoadMoreTimeout){
          clearTimeout(discoverLoadMoreTimeout);
          discoverLoadMoreTimeout = null;
        }
        if (discoverLoadMoreBtn){
          discoverLoadMoreBtn.disabled = false;
          discoverLoadMoreBtn.textContent = "Load More";
        }
      }catch(e){
        if (requestSeq !== discoverActiveRequestSeq){
          return;
        }
        if (discoverLoadMoreTimeout){
          clearTimeout(discoverLoadMoreTimeout);
          discoverLoadMoreTimeout = null;
        }
        if (discoverLoadMoreBtn){
          discoverLoadMoreBtn.disabled = false;
          discoverLoadMoreBtn.textContent = "Load More";
        }
        setStatus("Discover failed: " + (e.message || e), "bad");
      }
    
      discoverLoadInFlightKey = "";
    }

    async function requestItem(card, btn, destination=""){
      const mediaType = String(card.getAttribute("data-media-type") || "");
      const tmdbId = Number(card.getAttribute("data-tmdb-id") || 0);

      if (!seerrConfigured){
        setStatus("Seerr is not configured for this user.", "bad");
        return;
      }
      if (!mediaType || !tmdbId){
        setStatus("Missing media info for request.", "bad");
        return;
      }

      const oldText = btn.textContent;
      btn.disabled = true;
      btn.textContent = "Requesting…";

      try{
        const payload = {
          mediaType: mediaType,
          mediaId: tmdbId,
        };
        if (mediaType === "tv" && destination){
          payload.destination = destination;
        }

        const r = await fetch("/api/seerr/request", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
        });

        const j = await r.json().catch(() => ({}));

        if (!r.ok || !j.ok){
          const errText = String(j.error || j.message || ("HTTP " + r.status));
          const combined = errText.toLowerCase();

          if (combined.includes("already exists") || combined.includes("already requested")){
            btn.textContent = "Already Requested";
            btn.disabled = true;
            btn.classList.add("libraryRequested");
            setStatus("Already requested.", "ok");
            return;
          }

          throw new Error(errText);
        }

        btn.textContent = "Requested";
        setStatus("Request sent successfully.", "ok");
      }catch(e){
        btn.disabled = false;
        btn.textContent = oldText;
        setStatus("Request failed: " + (e.message || e), "bad");
      }
    }

    async function hydrateLibraryState(){
      const cards = [...discoverGrid.querySelectorAll(".discoverItem[data-discover-key]")];
      if (!cards.length) return;

      const items = cards.map(card => ({
        key: String(card.getAttribute("data-discover-key") || ""),
        title: String(card.getAttribute("data-title") || ""),
        year: String(card.getAttribute("data-year") || ""),
        media_type: String(card.getAttribute("data-media-type") || ""),
        tmdb_id: String(card.getAttribute("data-tmdb-id") || ""),
        imdb_id: String(card.getAttribute("data-imdb-id") || ""),
        tvdb_id: String(card.getAttribute("data-tvdb-id") || ""),
      })).filter(x => x.key && x.title && x.media_type);

      if (!items.length) return;

      const itemByKey = new Map(items.map(x => [x.key, x]));
      const chunkSize = 80;
      const mergedHits = {};

      try{
        for (let i = 0; i < items.length; i += chunkSize){
          const chunk = items.slice(i, i + chunkSize);

          const r = await fetch("/api/discover/library-state", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ items: chunk }),
          });

          const j = await r.json().catch(() => ({}));
          if (!r.ok || !j.ok || !j.items) continue;

          Object.assign(mergedHits, j.items || {});
        }

        for (const card of cards){
          const key = String(card.getAttribute("data-discover-key") || "");
          const hit = mergedHits[key] || {};

          const btn = card.querySelector("[data-request]");
          if (!btn) continue;

          btn.classList.remove("libraryOwned", "libraryRequested");

          let finalLabel = "";
          let finalClass = "";

          const inLibrary = !!hit.in_library;
          const inRequested = !!hit.in_sonarr || !!hit.in_radarr;

          if (inLibrary){
            finalLabel = "Already in Library";
            finalClass = "libraryOwned";
          } else if (inRequested){
            finalLabel = "Already Requested";
            finalClass = "libraryRequested";
          }

          if (!finalLabel) continue;

          btn.disabled = true;
          btn.textContent = finalLabel;
          btn.classList.add(finalClass);
          btn.removeAttribute("data-request");

          const menu = card.querySelector("[data-tv-dest-menu]");
          if (menu){
            menu.classList.remove("open");
            menu.innerHTML = "";
          }
        }
      }catch(_){
      }
    }

    function getDiscoverScrollParent(el){
      let node = el;
      while (node && node.parentElement){
        node = node.parentElement;
        const style = window.getComputedStyle(node);
        const overflowY = style ? style.overflowY : "";
        const canScroll = overflowY === "auto" || overflowY === "scroll" || overflowY === "overlay";
        if (canScroll && node.scrollHeight > node.clientHeight){
          return node;
        }
      }
      return window;
    }

