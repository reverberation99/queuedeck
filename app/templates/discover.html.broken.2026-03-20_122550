            <div class="whyKey">Final score</div><div class="whyVal">${esc(Number(breakdown.final_score || 0).toFixed(3))}</div>
            <div class="whyKey">Status</div><div class="whyVal">${
              Number(breakdown.final_score || 0) >= Number(breakdown.hot_threshold || 0)
