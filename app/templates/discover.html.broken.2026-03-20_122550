            <div class="whyDivider"></div>
            <div class="whyKey">Final score</div><div class="whyVal">${esc(Number(breakdown.final_score || 0).toFixed(2))}</div>
          </div>
        `;

        return `
          <div class="discoverItem ${isRising ? "consensusHot" : ""} ${isSpecialHot ? "specialHot" : ""}" data-discover-key="${esc(item._discover_key || discoverItemKey(item))}" data-title="${esc(item.title || "")}" data-year="${esc(item.year || "")}" data-media-type="${esc(item.media_type)}" data-tmdb-id="${esc(item.tmdb_id || "")}" data-imdb-id="${esc(item.imdb_id || "")}" data-tvdb-id="${esc(item.tvdb_id || "")}">
            ${hotLabel ? `<div class="hotBadge">${hotLabel}</div>` : ``}
            <div class="poster">${poster}</div>
            <div class="body">
              <div class="rowTop">
                <div class="title">${title}${year ? ` (${year})` : ""}</div>
                <div class="pill">${esc(media)}</div>
