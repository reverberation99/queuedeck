    function getDiscoverPrimingStorage(){
      try{
        const raw = localStorage.getItem("qd_discover_priming");
        if (!raw) return null;
        const data = JSON.parse(raw);
        if (!data || !data.active) return null;

        const updated = Number(data.updated || 0);
        if (updated > 0 && (Date.now() - updated) > (20 * 60 * 1000)){
          localStorage.removeItem("qd_discover_priming");
          return null;
        }

        return data;
      }catch(e){
        return null;
      }
    }

    function clearDiscoverPrimingStorage(){
      try{
        localStorage.removeItem("qd_discover_priming");
      }catch(e){}
    }

    async function fetchDiscoverWarmStatus(){
      const r = await fetch("/api/discover/warm-status", {
        cache: "no-store",
        credentials: "same-origin"
      });
      return await r.json().catch(() => ({}));
    }

    async function waitForDiscoverPrimeIfNeeded(){
      let data = {};
      try{
        data = await fetchDiscoverWarmStatus();
      }catch(e){
        return false;
      }

      const localPriming = getDiscoverPrimingStorage();

      if (!data.running && !localPriming){
        setDiscoverPrimeOverlay(false);
        discoverPrimeActive = false;
        return false;
      }

      if (!data.running && localPriming){
        discoverPrimeActive = true;

        const phase = String(localPriming.message || "Preparing Discover data...").trim();
        const pct = Math.max(4, Math.min(100, Number(localPriming.percent || 10)));
        const eta = String(localPriming.eta || "").trim();

        setDiscoverPrimeOverlay(
          true,
          phase,
          pct,
          eta || "Please wait while QueueDeck finishes priming Discover."
        );

        if (discoverPrimePolling){
          clearInterval(discoverPrimePolling);
          discoverPrimePolling = null;
        }

        discoverPrimePolling = setInterval(async () => {
          const localState = getDiscoverPrimingStorage();
          if (localState){
            const phase = String(localState.message || "Preparing Discover data...").trim();
            const pct = Math.max(4, Math.min(100, Number(localState.percent || 10)));
            const eta = String(localState.eta || "").trim();

            setDiscoverPrimeOverlay(
              true,
              phase,
              pct,
              eta || "Please wait while QueueDeck finishes priming Discover."
            );
            return;
          }

          clearInterval(discoverPrimePolling);
          discoverPrimePolling = null;
          discoverPrimeActive = false;
          clearDiscoverPrimingStorage();

          setDiscoverPrimeOverlay(true, "Discover ready.", 100, "Loading results...");
          setTimeout(() => setDiscoverPrimeOverlay(false), 900);

          loadDiscover(1, false);
        }, 900);

        return true;
      }

      discoverPrimeActive = true;

      const phase = String(data.message || "Preparing Discover data...").trim();
      const eta = String(data.eta_bucket || "").trim();
      const total = Math.max(1, Number(data.total || 1));
      const progress = Math.max(0, Number(data.progress || 0));
      const pct = Math.max(4, Math.min(100, Number(data.percent || Math.round((progress / total) * 100) || 0)));

      setDiscoverPrimeOverlay(
        true,
        phase,
        pct,
        eta || "Please wait while QueueDeck finishes priming Discover."
      );

      if (discoverPrimePolling){
        clearInterval(discoverPrimePolling);
        discoverPrimePolling = null;
      }

      discoverPrimePolling = setInterval(async () => {
        try{
          const j = await fetchDiscoverWarmStatus();
          const running = !!j.running;
          const total = Math.max(1, Number(j.total || 1));
          const progress = Math.max(0, Number(j.progress || 0));
          const pct = Math.max(4, Math.min(100, Number(j.percent || Math.round((progress / total) * 100) || 0)));
          const phase = String(j.message || "Preparing Discover data...").trim();
          const eta = String(j.eta_bucket || "").trim();

          if (running){
            setDiscoverPrimeOverlay(
              true,
              phase,
              pct,
              eta || "Please wait while QueueDeck finishes priming Discover."
            );
            return;
          }

          clearInterval(discoverPrimePolling);
          discoverPrimePolling = null;
          discoverPrimeActive = false;

          setDiscoverPrimeOverlay(true, "Discover ready.", 100, "Loading results...");
          setTimeout(() => setDiscoverPrimeOverlay(false), 900);

          loadDiscover(1, false);
        }catch(e){
          console.warn("discover prime poll failed", e);
        }
      }, 1200);

      return true;
    }

