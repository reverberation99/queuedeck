    function qdForYouScore(item, profile){
      if (!profile || !profile.ok) return Number(item.composite_score || 0);

      if (qdIsWatchedByProfile(item, profile)) return -9999;

      let score = Number(item.composite_score || 0) * 0.55;

      const genreWeights = profile.genre_weights || {};
      const itemGenres = Array.isArray(item.genres) ? item.genres : [];
      let genreBoost = 0;

      for (const g of itemGenres){
        if (g && typeof g === "object"){
          const name = String(g.name || "").trim();
          if (name && genreWeights[name] !== undefined){
            genreBoost += Number(genreWeights[name] || 0);
          }
        } else {
          const name = String(g || "").trim();
          if (name && genreWeights[name] !== undefined){
            genreBoost += Number(genreWeights[name] || 0);
          }
        }
      }

      score += Math.min(genreBoost, 0.35) * 0.20;

      const mediaType = String(item.media_type || "").trim().toLowerCase();
      if (profile.preferred_media === "movie" && mediaType === "movie") score += 0.08;
      if (profile.preferred_media === "tv" && mediaType === "tv") score += 0.08;

      const itemYear = Number(String(item.year || "").trim()) || 0;
      const yearCenter = Number(profile.year_center || 0);
      if (itemYear && yearCenter){
        const diff = Math.abs(itemYear - yearCenter);
        if (diff <= 2) score += 0.08;
        else if (diff <= 5) score += 0.05;
        else if (diff <= 10) score += 0.02;
      }

      const providerScores = item.provider_scores || {};
      const looksAnime =
        providerScores.anilist_anime !== undefined ||
        providerScores.jikan_anime_hot !== undefined ||
        providerScores.jikan_anime_rising !== undefined;

      if (looksAnime && Number(profile.anime_affinity || 0) >= 0.35){
        score += 0.08 * Number(profile.anime_affinity || 0);
      }

      if (Number(item.in_library_score || 0) > 0) score -= 0.15;
      if (Number(item.requested_score || 0) > 0) score -= 0.10;

      return Number(score.toFixed(4));
    }

