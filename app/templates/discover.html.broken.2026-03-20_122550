    function qdSeerrEscape(s){
      return String(s || "").replace(/[&<>"']/g, m => ({
        "&":"&amp;",
        "<":"&lt;",
        ">":"&gt;",
        '"':"&quot;",
        "'":"&#39;"
      }[m]));
    }

    function qdAdjustDiscoverMediaForSource(){
      if (!discoverSource || !discoverMedia) return;

      const src = String(discoverSource.value || "").trim();

      const movieOnlySources = new Set([
        "letterboxd",
        "letterboxd_aggregate"
      ]);

      const tvOnlySources = new Set([
        "anime_aggregate",
        "anilist_trending",
        "anilist_popular",
        "anilist_genre",
        "jikan_anime_hot",
        "jikan_anime_rising",
        "tvmaze_airing"
      ]);

      if (movieOnlySources.has(src)){
        if (String(discoverMedia.value || "") !== "all"){
          discoverMedia.value = "all";
        }
        return;
      }

      if (tvOnlySources.has(src)){
        if (String(discoverMedia.value || "") !== "tv"){
          discoverMedia.value = "tv";
        }
        return;
      }
    }

    function qdSeerrStatusLabel(v){
      const n = Number(v);
      if (Number.isNaN(n)) return v ? String(v) : "";
      if (n === 1) return "Unknown";
      if (n === 2) return "Pending";
      if (n === 3) return "Processing";
      if (n === 4) return "Partially Available";
      if (n === 5) return "Available";
      return "Status " + String(v);
    }

    function qdOpenSeerrSearch(){
      const modal = document.getElementById("qdSeerrSearchModal");
      if (!modal) return;
      modal.style.display = "flex";
      const input = document.getElementById("qdSeerrQuery");
      if (input){
        input.focus();
        const q = String(input.value || "").trim();
        if (q.length >= 2){
          qdSeerrSearch(q);
        }
      }
    }

    function qdCloseSeerrSearch(){
      const modal = document.getElementById("qdSeerrSearchModal");
      if (modal) modal.style.display = "none";
    }

    function qdOpenTvChoiceModal(){
      const modal = document.getElementById("qdSeerrTvChoiceModal");
      if (modal) modal.style.display = "flex";
    }

    function qdCloseTvChoiceModal(){
      const modal = document.getElementById("qdSeerrTvChoiceModal");
      if (modal) modal.style.display = "none";
      window.qdSeerrPendingTvItem = null;
    }

    let qdSeerrTvDestinations = [];
    window.qdSeerrPendingTvItem = null;

    async function qdSeerrLoadTvDestinations(){
      try{
        const r = await fetch("/api/seerr/tv-destinations", { cache: "no-store" });
        const j = await r.json().catch(() => ({}));
        if (r.ok && j.ok && Array.isArray(j.destinations)){
          qdSeerrTvDestinations = j.destinations;
        } else {
          qdSeerrTvDestinations = [];
        }
      }catch(_){
        qdSeerrTvDestinations = [];
      }
    }

    function qdSeerrResultCard(item){
      const poster = item.poster_url || "";
      const year = item.year || "";
      const mediaType = item.media_type === "tv" ? "TV" : "Movie";
      const requested = !!(item.request && item.request.id);
      const status = qdSeerrStatusLabel(item.status || item.status4k || "");
      const title = qdSeerrEscape(item.title || "");
      const resultKey = `${item.media_type || ""}:${item.tmdb_id || item.title || ""}:${item.year || ""}`;

      let badge = "";
      if (requested){
        badge = '<div data-qd-seerr-badge="1" style="margin-top:6px; font-size:12px; color:#9fe3a7;">Already Requested</div>';
      } else if (status){
        badge = '<div data-qd-seerr-badge="1" style="margin-top:6px; font-size:12px; color:#9ecbff;">' + qdSeerrEscape(status) + '</div>';
      } else {
        badge = '<div data-qd-seerr-badge="1" style="margin-top:6px; font-size:12px; color:#9ecbff;">&nbsp;</div>';
      }

      return `
        <div data-qd-seerr-card="1" data-qd-seerr-key="${qdSeerrEscape(resultKey)}" data-title="${title}" data-year="${qdSeerrEscape(year)}" data-media-type="${qdSeerrEscape(item.media_type || "")}" data-tmdb-id="${qdSeerrEscape(item.tmdb_id || "")}" data-imdb-id="${qdSeerrEscape(item.imdb_id || "")}" data-tvdb-id="${qdSeerrEscape(item.tvdb_id || "")}" style="background:rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.10); border-radius:14px; padding:10px;">
          <div style="aspect-ratio:2/3; overflow:hidden; border-radius:10px; background:rgba(255,255,255,.03); display:flex; align-items:center; justify-content:center;">
            ${poster ? `<img src="${poster}" alt="${title}" style="width:100%; height:100%; object-fit:cover;">` : `<div style="opacity:.45; font-size:12px;">No Poster</div>`}
          </div>
          <div style="margin-top:8px; font-size:14px; font-weight:600; line-height:1.25;">${title}</div>
          <div style="margin-top:4px; font-size:12px; opacity:.72;">${qdSeerrEscape(mediaType)}${year ? " • " + qdSeerrEscape(year) : ""}</div>
          ${badge}
          <button class="btn" type="button" data-qd-seerr-request="${item.tmdb_id}" data-qd-seerr-type="${item.media_type}" style="margin-top:10px; width:100%;" ${requested ? "disabled" : ""}>
            ${requested ? "Already Requested" : (item.media_type === "tv" ? "Request TV" : "Request")}
          </button>
        </div>
      `;
    }

    function qdSeerrOpenTvChoice(item){
      window.qdSeerrPendingTvItem = item;

      const title = document.getElementById("qdSeerrTvChoiceTitle");
      const list = document.getElementById("qdSeerrTvChoiceList");
      if (!title || !list) return;

      title.textContent = "Choose TV destination for " + (item.title || "show");
      list.innerHTML = "";

      const dests = Array.isArray(qdSeerrTvDestinations) ? qdSeerrTvDestinations : [];
      for (const d of dests){
        const btn = document.createElement("button");
        btn.type = "button";
        btn.className = "btn";
        btn.style.textAlign = "left";
        btn.style.padding = "12px 14px";
        btn.innerHTML = `
          <div style="font-weight:700;">${qdSeerrEscape(d.label || d.key || "Destination")}</div>
          <div style="font-size:12px; opacity:.72; margin-top:4px;">
            Root: ${qdSeerrEscape(d.rootFolder || "")}
            • Profile ID: ${qdSeerrEscape(d.profileId || "")}
            • Server ID: ${qdSeerrEscape(d.serverId || "")}
          </div>
        `;
        btn.addEventListener("click", () => qdSeerrSendRequest(item, d.key || "tv"));
        list.appendChild(btn);
      }

      qdOpenTvChoiceModal();
    }

    async function qdSeerrSendRequest(item, forcedDestination=null){
      const status = document.getElementById("qdSeerrStatus");
      try{
        const body = {
          mediaType: item.media_type,
          mediaId: item.tmdb_id
        };

        if (item.media_type === "tv"){
          body.destination = forcedDestination || "tv";
          if (item.tvdb_id) body.tvdbId = item.tvdb_id;
        }

        const r = await fetch("/api/seerr/request", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(body)
        });

        const j = await r.json().catch(() => ({}));

        if (!r.ok || !j.ok){
          const errText = String(j.error || j.message || ("HTTP " + r.status));
          const bodyText = String(j.body || "");
          const combined = (errText + " " + bodyText).toLowerCase();

          if (combined.includes("already exists") || combined.includes("already requested")){
            if (status) status.textContent = "Already requested.";
            return;
          }

          const extra = j.body ? (" — " + j.body) : "";
          if (status) status.textContent = "Request failed: " + errText + extra;
          return;
        }

        if (item.media_type === "tv"){
          qdCloseTvChoiceModal();
        }

        if (status) status.textContent = "Request sent for " + (item.title || "item") + ".";
        await qdSeerrSearch(document.getElementById("qdSeerrQuery")?.value || "");
      }catch(e){
        if (status) status.textContent = "Request failed: " + (e.message || e);
      }
    }

    async function qdSeerrHydrateSearchState(){
      const box = document.getElementById("qdSeerrResults");
      if (!box) return;

      const cards = [...box.querySelectorAll("[data-qd-seerr-card='1']")];
      if (!cards.length) return;

      const items = cards.map(card => ({
        key: String(card.getAttribute("data-qd-seerr-key") || ""),
        title: String(card.getAttribute("data-title") || ""),
        year: String(card.getAttribute("data-year") || ""),
        media_type: String(card.getAttribute("data-media-type") || "").toLowerCase(),
        tmdb_id: String(card.getAttribute("data-tmdb-id") || ""),
        imdb_id: String(card.getAttribute("data-imdb-id") || ""),
        tvdb_id: String(card.getAttribute("data-tvdb-id") || "")
      }));

      try{
        const r = await fetch("/api/discover/library-state", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ items })
        });

        const j = await r.json().catch(() => ({}));
        if (!r.ok || !j.ok || !j.items) return;

        cards.forEach(card => {
          const key = String(card.getAttribute("data-qd-seerr-key") || "");
          const hit = j.items[key] || {};
          const btn = card.querySelector("[data-qd-seerr-request]");
          const badge = card.querySelector("[data-qd-seerr-badge='1']");
          if (!btn || !badge) return;

          if (hit.in_library){
            btn.disabled = true;
            btn.textContent = "In Library";
            btn.classList.remove("primary");
            btn.classList.add("secondary");
            btn.style.background = "rgba(80,200,120,.16)";
            btn.style.borderColor = "rgba(120,220,150,.28)";
            btn.style.color = "#dff7e7";
            btn.style.cursor = "not-allowed";
            badge.textContent = "In Library";
            badge.style.color = "#9fe3a7";
          } else if (hit.in_sonarr || hit.in_radarr){
            btn.disabled = true;
            btn.textContent = "Already Requested";
            btn.style.cursor = "not-allowed";
            badge.textContent = "Already Requested";
            badge.style.color = "#9fe3a7";
          }
        });
      }catch(_){
      }
    }

    async function qdSeerrSearch(q){
      const status = document.getElementById("qdSeerrStatus");
      const box = document.getElementById("qdSeerrResults");
      if (!status || !box) return;

      q = String(q || "").trim();

      if (q.length < 2){
        box.innerHTML = "";
        status.textContent = "Type 2+ characters to search.";
        return;
      }

      status.textContent = "Searching...";
      box.innerHTML = "";

      try{
        const r = await fetch("/api/seerr/search?q=" + encodeURIComponent(q), { cache: "no-store" });
        const j = await r.json().catch(() => ({}));

        if (!r.ok || j.ok === false){
          status.textContent = "Search failed: " + (j.error || ("HTTP " + r.status));
          return;
        }

        if (j.configured === false){
          status.textContent = "Seerr is not configured for this user.";
          return;
        }

        const items = Array.isArray(j.results) ? j.results : [];
        if (!items.length){
          status.textContent = "No results.";
          return;
        }

        status.textContent = "Found " + items.length + " result" + (items.length === 1 ? "" : "s") + ".";
        box.innerHTML = items.map(qdSeerrResultCard).join("");
        await qdSeerrHydrateSearchState();

        box.querySelectorAll("[data-qd-seerr-request]").forEach(btn => {
          const id = String(btn.getAttribute("data-qd-seerr-request") || "");
          const item = items.find(x => String(x.tmdb_id) === id);
          if (!item || btn.disabled) return;

          btn.addEventListener("click", () => {
            if (item.media_type === "tv"){
              qdSeerrOpenTvChoice(item);
            } else {
              qdSeerrSendRequest(item);
            }
          });
        });
      }catch(e){
        status.textContent = "Search failed: " + (e.message || e);
      }
    }

    (async function init(){
      const qdSearchInput = document.getElementById("qdSeerrQuery");
      const qdSearchResults = document.getElementById("qdSeerrResults");
      const qdSearchStatus = document.getElementById("qdSeerrStatus");
      if (qdSearchInput) qdSearchInput.value = "";
      if (qdSearchResults) qdSearchResults.innerHTML = "";
      if (qdSearchStatus) qdSearchStatus.textContent = "Type 2+ characters to search.";
      normalizeDiscoverFilters();

      try{
        const r = await fetch("/settings/api", { cache: "no-store" });
        const j = await r.json().catch(() => ({}));
        const raw = Number(j.limit_discover_results || 24);
        qdDiscoverResultsLimit = Math.max(6, Math.min(48, raw || 24));
      }catch(_){
        qdDiscoverResultsLimit = 24;
      }
      await loadSeerrConfig();
      await loadTvDestinations();
      await qdSeerrLoadTvDestinations();
      await loadLetterboxdSources();
      qdSetGenreOptionsForSource();
      qdSetSortOptionsForMode();

      const qdOpenBtn = document.getElementById("qdOpenSeerrSearch");
      const qdCloseBtn = document.getElementById("qdCloseSeerrSearch");
      const qdModal = document.getElementById("qdSeerrSearchModal");
      const qdInput = document.getElementById("qdSeerrQuery");
      const qdTvChoiceModal = document.getElementById("qdSeerrTvChoiceModal");
      const qdTvChoiceClose = document.getElementById("qdSeerrTvChoiceClose");

      if (qdOpenBtn) qdOpenBtn.addEventListener("click", qdOpenSeerrSearch);
      if (qdCloseBtn) qdCloseBtn.addEventListener("click", qdCloseSeerrSearch);
      if (qdTvChoiceClose) qdTvChoiceClose.addEventListener("click", qdCloseTvChoiceModal);

      if (qdModal){
        qdModal.addEventListener("click", (e) => {
          if (e.target === qdModal) qdCloseSeerrSearch();
        });
      }

      if (qdTvChoiceModal){
        qdTvChoiceModal.addEventListener("click", (e) => {
          if (e.target === qdTvChoiceModal) qdCloseTvChoiceModal();
        });
      }

      if (qdInput){
        let qdTimer;
        qdInput.addEventListener("input", () => {
          clearTimeout(qdTimer);
          qdTimer = setTimeout(() => qdSeerrSearch(qdInput.value), 350);
        });
      }

      const gated = await waitForDiscoverPrimeIfNeeded();
      if (!gated){
        await loadDiscover(1, false);
      }
    })();
  </script>
  <script>
    (function(){
      const menu = document.getElementById("userMenu");
      const btn = document.getElementById("userMenuBtn");
      if (!menu || !btn) return;

      function closeMenu(){
        menu.classList.remove("open");
        btn.setAttribute("aria-expanded", "false");
      }

      function openMenu(){
        menu.classList.add("open");
        btn.setAttribute("aria-expanded", "true");
      }

      btn.addEventListener("click", (e) => {
        e.preventDefault();
        e.stopPropagation();
        menu.classList.contains("open") ? closeMenu() : openMenu();
      });

      document.addEventListener("click", (e) => {
        if (!menu.contains(e.target)) closeMenu();
      });

      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") closeMenu();
      });
    })();
  </script>

