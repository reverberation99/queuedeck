            ${letterboxdLabels.length ? `<div class="whyKey">Feed overlap</div><div class="whyVal">${esc(String(letterboxdFeedCount))}</div>` : ``}
            <div class="whyReason">Consensus changes the final score directly. One-source items are penalized, while multi-source agreement boosts confidence.</div>

            ${whyReasonsHtml}

            <div class="whyDivider"></div>

