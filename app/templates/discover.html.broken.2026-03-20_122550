        });
      }

      const weightedRating = (i) => {
        const priorMean = 6.8;
        const minVotes = 200;

        const R = Number(i.vote_average || 0);
        const v = Number(i.vote_count || 0);

        if (R <= 0) return 0;

        return ((v / (v + minVotes)) * R) + ((minVotes / (v + minVotes)) * priorMean);
      };

      if (mode === "hidden_gems"){
        const hiddenGemScoreStrong = (i) => {
          const priorMean = 6.9;
          const minVotes = 120;

          const scores = i.provider_scores || {};
          const isAniListOnly =
            scores.anilist_anime !== undefined &&
            scores.tmdb_trending === undefined &&
            scores.tmdb_popular === undefined &&
            scores.trakt_trending === undefined &&
            scores.trakt_popular === undefined &&
            scores.letterboxd === undefined &&
            scores.tvmaze_airing === undefined;

          const anilistSignal = Number(scores.anilist_anime || 0);

          const rawRating = Number(i.vote_average || 0);
          const rawVotes = Number(i.vote_count || 0);
          const rawPopularity = Number(i.popularity || 0);

          const R = rawRating > 0
            ? rawRating
            : (isAniListOnly ? Math.max(5.8, Number((anilistSignal * 10).toFixed(2))) : 0);

          const v = rawVotes > 0
            ? rawVotes
            : (isAniListOnly ? Math.max(12, Math.round(anilistSignal * 420)) : 0);

          // Anime titles enriched from TMDb often carry huge popularity values that make
          // hidden gems impossible. Compress them heavily for AniList-only scoring.
          const pop = isAniListOnly
            ? (
                rawPopularity > 0
                  ? Math.max(8, Number((Math.log10(rawPopularity + 1) * 11.5).toFixed(2)))
                  : Math.max(6, Number((52 - (anilistSignal * 26)).toFixed(2)))
              )
            : rawPopularity;

          const hits = Number(i.provider_hits || 0);

          const wr = R > 0
            ? (((v / (v + minVotes)) * R) + ((minVotes / (v + minVotes)) * priorMean))
            : 0;

          const wrNorm = Math.max(0, Math.min(wr / 10, 1));

          let obscurity = 0;
          if (pop <= 4) obscurity = 1.00;
          else if (pop <= 8) obscurity = 0.95;
          else if (pop <= 14) obscurity = 0.88;
          else if (pop <= 22) obscurity = 0.72;
          else if (pop <= 32) obscurity = 0.48;
          else if (pop <= 45) obscurity = 0.18;
          else obscurity = 0.00;

          let confidence = 0;
          if (v >= 40 && v <= 600) confidence = 1.00;
          else if (v >= 20 && v < 40) confidence = 0.72;
          else if (v > 600 && v <= 1200) confidence = 0.45;
          else if (v > 1200) confidence = 0.10;
          else confidence = 0.20;

          let nicheBonus = 0.0;
          if (hits <= 1) nicheBonus = 1.00;
          else if (hits === 2) nicheBonus = 0.55;
          else if (hits === 3) nicheBonus = 0.10;
          else nicheBonus = 0.00;

          let mainstreamSignals = 0;
          if (scores.tmdb_popular !== undefined) mainstreamSignals += 1;
          if (scores.trakt_popular !== undefined) mainstreamSignals += 1;
          if (scores.tmdb_trending !== undefined) mainstreamSignals += 1;
          if (scores.trakt_trending !== undefined) mainstreamSignals += 1;
          if (!isAniListOnly && scores.anilist_anime !== undefined && pop >= 30) mainstreamSignals += 1;

          let mainstreamPenalty = 0.0;
          if (isAniListOnly){
            if (pop >= 65) mainstreamPenalty += 0.12;
            else if (pop >= 50) mainstreamPenalty += 0.08;
            else if (pop >= 36) mainstreamPenalty += 0.04;
          } else {
            if (pop >= 70) mainstreamPenalty += 0.34;
            else if (pop >= 50) mainstreamPenalty += 0.22;
            else if (pop >= 35) mainstreamPenalty += 0.14;
            else if (pop >= 25) mainstreamPenalty += 0.08;
          }

          mainstreamPenalty += (mainstreamSignals * (isAniListOnly ? 0.04 : 0.10));

          const ratingContribution = (wrNorm * 0.40);
          const obscurityContribution = (obscurity * 0.36);
          const confidenceContribution = (confidence * 0.12);
          const nicheContribution = (nicheBonus * 0.12);

          const score =
            ratingContribution +
            obscurityContribution +
            confidenceContribution +
            nicheContribution -
            mainstreamPenalty;

          return {
            score: Math.max(0, Math.min(Number(score.toFixed(4)), 1)),
            breakdown: {
              weighted_rating: Number(wr.toFixed(2)),
              weighted_rating_norm: Number(wrNorm.toFixed(4)),
              popularity: pop,
              vote_count: v,
              provider_hits: hits,
              obscurity: Number(obscurity.toFixed(4)),
              confidence: Number(confidence.toFixed(4)),
              niche_bonus: Number(nicheBonus.toFixed(4)),
              mainstream_signals: mainstreamSignals,
              mainstream_penalty: Number(mainstreamPenalty.toFixed(4)),
              rating_contribution: Number(ratingContribution.toFixed(4)),
              obscurity_contribution: Number(obscurityContribution.toFixed(4)),
              confidence_contribution: Number(confidenceContribution.toFixed(4)),
              niche_contribution: Number(nicheContribution.toFixed(4)),
              final_score: Math.max(0, Math.min(Number(score.toFixed(4)), 1)),
            }
          };
        };

        items = [...(items || [])]
          .map(i => {
            const hg = hiddenGemScoreStrong(i);
            return {
              ...i,
              hidden_gem_score: hg.score,
              hidden_gem_breakdown: hg.breakdown,
