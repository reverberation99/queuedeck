            const bScore = Number(b.composite_score || 0);

            const aHits = Math.max(Number(a.provider_hits || 0), aLabels);
            const bHits = Math.max(Number(b.provider_hits || 0), bLabels);

            const aHot = (aHits >= 2 && aScore >= aHotThreshold) ? 1 : 0;
            const bHot = (bHits >= 2 && bScore >= bHotThreshold) ? 1 : 0;

            if (bHot !== aHot) return bHot - aHot;
            return bScore - aScore;
          });
        } else if (sortMode === "rising_first"){
          items = [...(items || [])].sort((a, b) => {
            const aLabels = Array.isArray(a.letterboxd_labels) ? a.letterboxd_labels.filter(Boolean).length : 0;
            const bLabels = Array.isArray(b.letterboxd_labels) ? b.letterboxd_labels.filter(Boolean).length : 0;

            const aHotThreshold = Number((a.score_breakdown || {}).hot_threshold || 0.82);
            const bHotThreshold = Number((b.score_breakdown || {}).hot_threshold || 0.82);

            const aScore = Number(a.composite_score || 0);
            const bScore = Number(b.composite_score || 0);

            const aHits = Math.max(Number(a.provider_hits || 0), aLabels);
            const bHits = Math.max(Number(b.provider_hits || 0), bLabels);

            const aHot = (aHits >= 2 && aScore >= aHotThreshold) ? 1 : 0;
            const bHot = (bHits >= 2 && bScore >= bHotThreshold) ? 1 : 0;

            const aRising = (!aHot && aHits >= 2 && aScore >= Math.max(0, aHotThreshold - 0.12)) ? 1 : 0;
            const bRising = (!bHot && bHits >= 2 && bScore >= Math.max(0, bHotThreshold - 0.12)) ? 1 : 0;

            if (bRising !== aRising) return bRising - aRising;
            if (bHot !== aHot) return bHot - aHot;
            return bScore - aScore;
          });
        } else if (sortMode === "sources_desc"){
          items = [...(items || [])].sort((a, b) => {
            const ah = Number(a.provider_hits || 0);
