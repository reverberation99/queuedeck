    function prefetchDiscoverPage(page=1){
      const key = discoverPrefetchKey(page);
      if (discoverPrefetchCache.has(key) || discoverPrefetchInFlight.has(key)) return;

      console.debug("[discover-prefetch] start", key);

      const promise = fetch(discoverBuildUrl(page), {
        cache: "no-store",
        credentials: "same-origin"
      })
        .then(async (r) => {
          const j = await r.json().catch(() => ({}));
          if (r.ok && j && j.ok){
            const payload = { r: { ok: true, status: r.status }, j };
            discoverPrefetchCache.set(key, payload);
            console.debug("[discover-prefetch] ready", key, Array.isArray(j.items) ? j.items.length : 0);
            return payload;
          }
          console.debug("[discover-prefetch] not-ok", key, r.status);
          return null;
        })
        .catch((e) => {
          console.debug("[discover-prefetch] error", key, String(e && e.message || e || ""));
          return null;
        })
        .finally(() => {
          discoverPrefetchInFlight.delete(key);
