    function setDiscoverPrimeOverlay(show, message="", percent=0, meta=""){
      const overlay = document.getElementById("discoverPrimeOverlay");
      const textEl = document.getElementById("discoverPrimeText");
      const barEl = document.getElementById("discoverPrimeBar");
