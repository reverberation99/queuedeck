      }

      if (yearFromNum || yearToNum){
        items = (items || []).filter(i => {
          const y = Number(String(i.year || "").trim());
          if (!Number.isFinite(y) || y <= 0) return false;
          if (yearFromNum && y < yearFromNum) return false;
          if (yearToNum && y > yearToNum) return false;
