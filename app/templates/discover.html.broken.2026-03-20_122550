    async function fetchDiscoverPayload(page=1){
      const key = discoverPrefetchKey(page);

      if (discoverPrefetchCache.has(key)){
        const cached = discoverPrefetchCache.get(key);
        discoverPrefetchCache.delete(key);
        console.debug("[discover-prefetch] cache-hit", key);
        return cached;
      }

      if (discoverPrefetchInFlight.has(key)){
        console.debug("[discover-prefetch] await-inflight", key);
        const inflight = discoverPrefetchInFlight.get(key);
        try{
          const cached = await inflight;
          if (cached){
            discoverPrefetchCache.delete(key);
            return cached;
          }
        }catch(_){}
      }

      console.debug("[discover-prefetch] direct-fetch", key);
      const r = await fetch(discoverBuildUrl(page), {
        cache: "no-store",
        credentials: "same-origin"
      });
      const j = await r.json().catch(() => ({}));
      return { r, j };
