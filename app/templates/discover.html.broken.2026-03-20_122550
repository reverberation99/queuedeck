          : ``;

        const tvmazeWhy = breakdownScores.tvmaze_airing !== undefined
          ? `<div class="whyKey">TVMaze airing</div><div class="whyVal">${esc(Number(breakdownScores.tvmaze_airing).toFixed(2))}</div>`
          : ``;

        const anilistWhy = breakdownScores.anilist_anime !== undefined
          ? `<div class="whyKey">AniList score</div><div class="whyVal">${esc(Number(breakdownScores.anilist_anime).toFixed(2))}</div>`
