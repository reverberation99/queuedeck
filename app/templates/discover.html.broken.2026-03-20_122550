  <title>QueueDeck Discover</title>
<style>
    :root{
      --bg0:#07090c;
      --bg1:#0b0f14;
      --card: rgba(255,255,255,.055);
      --border: rgba(255,255,255,.10);
      --text: rgba(255,255,255,.92);
      --muted: rgba(255,255,255,.64);
      --accent:#7c5cff;
      --accent2:#4ea1ff;
      --shadow: 0 20px 60px rgba(0,0,0,.55);
      --r: 20px;
    }

    *{ box-sizing:border-box; }
    html,body{ margin:0; min-height:100%; }
    body{
      font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
      color: var(--text);
      background:
        radial-gradient(900px 600px at 15% 0%, rgba(124,92,255,.14), transparent 60%),
        radial-gradient(900px 700px at 100% 0%, rgba(78,161,255,.10), transparent 55%),
        linear-gradient(180deg, var(--bg0), var(--bg1));
      padding: 28px;
    }

    .wrap{ max-width: 1400px; margin: 0 auto; }

    .topbar{
      display:flex;
      justify-content:space-between;
      align-items:flex-start;
      gap:16px;
      margin-bottom:18px;
      flex-wrap:wrap;
    }

    .brand{
      display:flex;
      align-items:flex-start;
      gap:16px;
    }

    .logo{
      width:54px;
        height:54px;
      border-radius:14px;
      display:grid;
      place-items:center;
      border:1px solid rgba(255,255,255,.12);
      background: rgba(255,255,255,.05);
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,.08),
        0 10px 28px rgba(0,0,0,.40);
      overflow:hidden;
    }

    .logo img{
      width:50px;
        height:50px;
      display:block;
                              object-fit: contain;
object-fit: contain;
object-fit: contain;
filter: drop-shadow(0 4px 10px rgba(0,0,0,.4));
    }

    h1{
      margin:0;
      font-size:22px;
      line-height:1.1;
      font-weight:900;
      letter-spacing:.2px;
    }

    .sub{
      margin:6px 0 0;
      color:var(--muted);
      font-size:14px;
      line-height:1.35;
      max-width:760px;
    }

    .top-links{
      display:flex;
      gap:10px;
      flex-wrap:wrap;
      align-items:center;
    }

    .userMenu{
      position:relative;
      display:flex;
      align-items:center;
      flex:0 0 auto;
    }

    .userMenuBtn{
      display:inline-flex;
      align-items:center;
      gap:10px;
      min-height:44px;
      padding:8px 12px 8px 8px;
      border-radius:999px;
      border:1px solid rgba(255,255,255,.10);
      background: rgba(255,255,255,.05);
      color:#fff;
      cursor:pointer;
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,.04),
        0 8px 22px rgba(0,0,0,.18);
    }

    .userMenuBtn:hover{
      background: rgba(255,255,255,.09);
      border-color: rgba(255,255,255,.16);
      transform: translateY(-1px);
    }

    .userAvatar{
      width:30px;
      height:30px;
      border-radius:999px;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      font-size:13px;
      font-weight:900;
      color:#fff;
      background: linear-gradient(135deg, var(--accent), var(--accent2));
    }

    .userMenuName{
      font-size:13px;
      font-weight:800;
      color: rgba(255,255,255,.92);
      white-space:nowrap;
    }

    .userMenuChevron{
      font-size:11px;
      color: rgba(255,255,255,.72);
      transition: transform .18s ease;
    }

    .userMenu.open .userMenuChevron{ transform: rotate(180deg); }

    .userDropdown{
      position:absolute;
      right:0;
      top:calc(100% + 10px);
      min-width:220px;
      border:1px solid rgba(255,255,255,.12);
      background: rgba(10,12,18,.94);
      backdrop-filter: blur(10px);
      border-radius:16px;
      box-shadow: 0 24px 70px rgba(0,0,0,.55);
      padding:8px;
      display:none;
      z-index:30;
    }

    .userMenu.open .userDropdown{ display:block; }

    .userDropdownHead{
      padding:10px 12px 8px;
      border-bottom:1px solid rgba(255,255,255,.08);
      margin-bottom:6px;
    }

    .userDropdownTitle{
      font-size:13px;
      font-weight:900;
      color: rgba(255,255,255,.94);
    }

    .userDropdownSub{
      margin-top:3px;
      font-size:12px;
      color: rgba(255,255,255,.62);
    }

    .userDropdown a{
      display:flex;
      align-items:center;
      padding:10px 12px;
      border-radius:12px;
      font-size:13px;
      font-weight:700;
      color: rgba(255,255,255,.88);
      text-decoration:none;
    }

    .userDropdown a:hover{
      background: rgba(255,255,255,.06);
      color:#fff;
    }

    .userDropdown a.danger{
      color: rgba(255,130,130,.95);
    }

    @media (max-width:760px){
      .userMenuName{ display:none; }
      .userMenuBtn{ padding-right:10px; }
    }

    .btn, button{
      border:none;
      border-radius:16px;
      padding:12px 18px;
      min-height:46px;
      font-weight:800;
      color:#fff;
      cursor:pointer;
      text-decoration:none;
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      font-size:14px;
      line-height:1;
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,.08),
        0 10px 26px rgba(0,0,0,.22);
    }

    .btn.secondary, button.secondary{
      background: rgba(255,255,255,.05);
      border:1px solid rgba(255,255,255,.10);
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,.04),
        0 8px 22px rgba(0,0,0,.18);
    }

    .btn.secondary:hover, button.secondary:hover{
      background: rgba(255,255,255,.09);
      border-color: rgba(255,255,255,.16);
      transform: translateY(-1px);
    }

    .btn:disabled, button:disabled{
      opacity:.65;
      cursor:not-allowed;
    }

    .card{
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 20px;
      box-shadow: var(--shadow);
      backdrop-filter: blur(10px);
      padding: 22px;
      margin-bottom: 18px;
    }

    .filters{
      display:grid;
      grid-template-columns: 1.2fr 1.2fr 1.2fr 1.2fr;
      gap:14px;
      align-items:end;
    }

    @media (max-width: 980px){
      .filters{ grid-template-columns: 1fr; }
    }

    .field{
      display:flex;
      flex-direction:column;
      gap:8px;
    }

    label{
      font-size:12px;
      font-weight:800;
      color:rgba(255,255,255,.85);
      letter-spacing:.2px;
    }

    select{
      width:100%;
      border:1px solid rgba(255,255,255,.14);
      background: rgba(0,0,0,.28);
      color:#fff;
      border-radius:14px;
      padding:12px 14px;
      outline:none;
    }

    .status{
      margin-top:14px;
      padding:11px 14px;
      border-radius:12px;
      border:1px solid rgba(255,255,255,.10);
      background: rgba(0,0,0,.18);
      color: rgba(255,255,255,.84);
      font-size:13px;
    }

    
    .discoverNotice{
      margin: 10px 0 14px;
      padding: 12px 14px;
      border-radius: 12px;
      background: rgba(255,255,255,.05);
      border: 1px solid rgba(255,255,255,.10);
      color: rgba(255,255,255,.88);
      font-size: .95rem;
      line-height: 1.45;
    }
    .discoverNotice a{
      color: inherit;
      text-decoration: underline;
      text-underline-offset: 2px;
    }

    .discoverPrimeOverlay{
      display:none;
      position: sticky;
      top: 76px;
      z-index: 30;
      margin: 10px 0 14px;
      padding: 16px;
      border-radius: 16px;
      border: 1px solid rgba(255,255,255,.12);
      background: rgba(10,12,18,.92);
      backdrop-filter: blur(10px);
      box-shadow: 0 18px 60px rgba(0,0,0,.45);
    }
    .discoverPrimeOverlay.show{
      display:block;
    }
    .discoverPrimeTitle{
      font-weight: 900;
      font-size: 14px;
      margin-bottom: 6px;
    }
    .discoverPrimeText{
      font-size: 12.5px;
      color: rgba(255,255,255,.74);
      line-height: 1.4;
      margin-bottom: 10px;
    }
    .discoverPrimeBarWrap{
      height: 10px;
      border-radius: 999px;
      background: rgba(255,255,255,.08);
      overflow: hidden;
      margin-bottom: 8px;
    }
    .discoverPrimeBar{
      height: 100%;
      width: 0%;
      border-radius: 999px;
      background: linear-gradient(90deg, rgba(124,92,255,.95), rgba(78,161,255,.92));
      transition: width .25s ease;
    }
    .discoverPrimeMeta{
      font-size: 12px;
      color: rgba(255,255,255,.68);
    }
    .discoverPrimeGate{
      pointer-events: none;
      opacity: .45;
      filter: saturate(.85);
    }

.status.bad{
      border-color: rgba(255,80,80,.35);
      background: rgba(255,80,80,.12);
      color:#ffd7d7;
    }

    .status.ok{
      border-color: rgba(80,200,120,.35);
      background: rgba(80,200,120,.12);
      color:#d8ffe5;
    }

    .discoverGrid{
      display:grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap:16px;
      margin-top:18px;
    }

    .discoverItem{
      border:1px solid rgba(255,255,255,.10);
      background: rgba(255,255,255,.04);
      border-radius:18px;
      overflow:hidden;
      display:flex;
      flex-direction:column;
      min-height:100%;
      position:relative;
      transition:
        transform .18s ease,
        box-shadow .18s ease,
        border-color .18s ease;
      isolation:isolate;
    }

    .discoverItem:hover{
      transform: translateY(-3px);
      box-shadow: 0 18px 40px rgba(0,0,0,.35);
    }

    .discoverItem.specialHot{
      border-color: rgba(255,140,60,.70);
      box-shadow:
        0 0 0 1px rgba(255,110,40,.18),
        0 0 22px rgba(255,100,20,.22),
        0 0 44px rgba(255,70,0,.14);
    }

    .discoverItem.specialHot::after{
      content:"";
      position:absolute;
      inset:-1px;
      border-radius:18px;
      pointer-events:none;
      box-shadow:
        inset 0 0 0 1px rgba(255,180,80,.18),
        0 0 18px rgba(255,120,40,.16);
    }

    .hotBadge{
      position:absolute;
      top:10px;
      right:10px;
      z-index:2;
      font-size:11px;
      font-weight:900;
      letter-spacing:.3px;
      color:#fff;
      border-radius:999px;
      padding:6px 10px;
      background: linear-gradient(135deg, rgba(255,120,40,.98), rgba(255,60,0,.95));
      box-shadow:
        0 8px 22px rgba(255,70,0,.28),
        inset 0 1px 0 rgba(255,255,255,.18);
    }

    .poster{
      aspect-ratio: 2 / 3;
      background: rgba(255,255,255,.04);
      overflow:hidden;
    }

    .poster img{
      width:100%;
      height:100%;
      object-fit:cover;
      display:block;
    }

    .posterPlaceholder{
      width:100%;
      height:100%;
      display:flex;
      align-items:center;
      justify-content:center;
      color:rgba(255,255,255,.45);
      font-size:13px;
      padding:16px;
      text-align:center;
    }

    .body{
      padding:14px;
      display:flex;
      flex-direction:column;
      gap:8px;
      flex:1 1 auto;
    }

    .rowTop{
      display:flex;
      justify-content:space-between;
      gap:10px;
      align-items:flex-start;
    }

    .title{
      font-size:15px;
      font-weight:900;
      line-height:1.25;
    }

    .pill{
      flex:0 0 auto;
      font-size:11px;
      font-weight:900;
      color:#fff;
      border:1px solid rgba(255,255,255,.14);
      background: rgba(255,255,255,.08);
      border-radius:999px;
      padding:5px 9px;
    }

    .meta{
      color:rgba(255,255,255,.72);
      font-size:12px;
      line-height:1.35;
    }

    .qdScore{
      display:inline-block;
      font-weight:900;
      color:#ff9a57;
    }

    .tmdbScore{
      display:inline-block;
      font-weight:800;
      color:#d7e7ff;
    }

    .gemScore{
      display:inline-block;
      font-weight:900;
      color:#8ee7c1;
    }

    .overview{
      color:rgba(255,255,255,.84);
      font-size:13px;
      line-height:1.45;
      display:-webkit-box;
      -webkit-line-clamp:4;
      -webkit-box-orient:vertical;
      overflow:hidden;
      min-height:72px;
    }

    .actions{
      display:grid;
      grid-template-columns: 1fr 1fr;
      gap:10px;
      margin-top:auto;
      padding-top:4px;
      align-items:stretch;
    }

    .actions .btn{
      width:100%;
      justify-content:center;
      text-align:center;
    }

    .actions .btn.full{
      grid-column: 1 / -1;
    }

    .foot{
      margin-top:16px;
      color:rgba(255,255,255,.62);
      font-size:12px;
      line-height:1.45;
    }
  
    .tvDestMenu{
      display:none;
      margin-top:10px;
      padding:10px;
      border-radius:14px;
      border:1px solid rgba(255,255,255,.10);
      background: rgba(0,0,0,.18);
      gap:8px;
      flex-wrap:wrap;
    }

    .tvDestMenu.open{
      display:flex;
    }

    .tvDestTitle{
      width:100%;
      font-size:12px;
      font-weight:800;
      color: rgba(255,255,255,.78);
      margin-bottom:2px;
    }

    .tvDestBtn{
      border:none;
      border-radius:12px;
      padding:10px 12px;
      min-height:40px;
      font-weight:800;
      color:#fff;
      cursor:pointer;
      background: rgba(255,255,255,.08);
      border:1px solid rgba(255,255,255,.10);
    }

    .tvDestBtn:hover{
      background: rgba(255,255,255,.12);
      border-color: rgba(255,255,255,.18);
    }

    .whyBtn{
      background: rgba(255,255,255,.06);
      border: 1px solid rgba(255,255,255,.10);
    }

    .whyBtn:hover{
      background: rgba(255,255,255,.10);
      border-color: rgba(255,255,255,.16);
    }

    
    .body{
      position:static;
    }

    
    
