          })
          .filter(i => {
            const hs = Number(i.hidden_gem_score || 0);
            const hits = Number(i.provider_hits || 0);
            const scores = i.provider_scores || {};

            const isAniListOnly =
              scores.anilist_anime !== undefined &&
              scores.tmdb_trending === undefined &&
              scores.tmdb_popular === undefined &&
              scores.trakt_trending === undefined &&
              scores.trakt_popular === undefined &&
              scores.letterboxd === undefined &&
              scores.tvmaze_airing === undefined;

            const anilistSignal = Number(scores.anilist_anime || 0);
            const rawRating = Number(i.vote_average || 0);
            const rawPopularity = Number(i.popularity || 0);

            const wr = rawRating > 0
              ? rawRating
              : (isAniListOnly ? Math.max(5.8, Number((anilistSignal * 10).toFixed(2))) : 0);

            const pop = isAniListOnly
              ? (
                  rawPopularity > 0
                    ? Math.max(8, Number((Math.log10(rawPopularity + 1) * 11.5).toFixed(2)))
                    : Math.max(6, Number((52 - (anilistSignal * 26)).toFixed(2)))
                )
              : rawPopularity;

            const mainstreamSource =
              scores.tmdb_popular !== undefined ||
              scores.trakt_popular !== undefined ||
              (scores.tmdb_trending !== undefined && pop >= 32) ||
              (scores.trakt_trending !== undefined && pop >= 32);

            if (isAniListOnly){
              return hs >= 0.28 && wr >= 5.2 && pop <= 72 && hits <= 5;
            }

            return hs >= 0.44 && wr >= 6.3 && pop <= 68 && hits <= 4 && !mainstreamSource;
          })
          .sort((a, b) => {
            const hs = Number(b.hidden_gem_score || 0) - Number(a.hidden_gem_score || 0);
            if (hs !== 0) return hs;

            const ap = Number(a.popularity || 0);
            const bp = Number(b.popularity || 0);
            if (ap !== bp) return ap - bp;

            return Number(b.vote_average || 0) - Number(a.vote_average || 0);
          });
      }

      if (mode === "hidden_gems"){
        if (sortMode === "trending"){
          items = [...(items || [])].sort((a, b) => {
            const ap = Number(a.popularity || 0);
            const bp = Number(b.popularity || 0);
            if (bp !== ap) return bp - ap;
            return Number(b.hidden_gem_score || 0) - Number(a.hidden_gem_score || 0);
          });
        } else if (sortMode === "trending_weighted"){
          items = [...(items || [])].sort((a, b) => {
            const normPop = (x) => Math.min(Number(x || 0), 100) / 100;
            const normRating = (x) => Math.min(Number(x || 0), 10) / 10;
            const normHits = (x) => Math.min(Number(x || 0), 6) / 6;
            const normGem = (x) => Math.min(Number(x || 0), 1);

            const aTrend =
              (normPop(a.popularity) * 0.40) +
              (normRating(a.vote_average) * 0.25) +
              (normHits(a.provider_hits) * 0.10) +
              (normGem(a.hidden_gem_score) * 0.25);

            const bTrend =
              (normPop(b.popularity) * 0.40) +
              (normRating(b.vote_average) * 0.25) +
              (normHits(b.provider_hits) * 0.10) +
              (normGem(b.hidden_gem_score) * 0.25);

            if (bTrend !== aTrend) return bTrend - aTrend;
            return Number(b.hidden_gem_score || 0) - Number(a.hidden_gem_score || 0);
          });
        } else if (sortMode === "popularity_asc"){
          items = [...(items || [])].sort((a, b) => {
            const ap = Number(a.popularity || 0);
            const bp = Number(b.popularity || 0);
            if (ap !== bp) return ap - bp;
            return Number(b.hidden_gem_score || 0) - Number(a.hidden_gem_score || 0);
          });
        } else if (sortMode === "rating_weighted"){
          items = [...(items || [])].sort((a, b) => {
            const aw = weightedRating(a);
            const bw = weightedRating(b);
            if (bw !== aw) return bw - aw;

            const av = Number(a.vote_count || 0);
            const bv = Number(b.vote_count || 0);
            if (bv !== av) return bv - av;

            return Number(b.hidden_gem_score || 0) - Number(a.hidden_gem_score || 0);
          });
        } else if (sortMode === "newest"){
          items = [...(items || [])].sort((a, b) => {
            const ay = Number(String(a.year || "").trim()) || 0;
            const by = Number(String(b.year || "").trim()) || 0;
            if (by !== ay) return by - ay;
            return Number(b.hidden_gem_score || 0) - Number(a.hidden_gem_score || 0);
          });
        } else {
          items = [...(items || [])].sort((a, b) => {
            const ah = Number(a.hidden_gem_score || 0);
            const bh = Number(b.hidden_gem_score || 0);
            if (bh !== ah) return bh - ah;

            const ap = Number(a.popularity || 0);
            const bp = Number(b.popularity || 0);
            if (ap !== bp) return ap - bp;

            return (Number(b.vote_average || 0) - Number(a.vote_average || 0));
          });
        }
      } else {
        if (sortMode === "for_you"){
          items = [...(items || [])]
            .map(i => ({
              ...i,
              for_you_score: qdForYouScore(i, QD_FOR_YOU_PROFILE)
            }))
            .filter(i => Number(i.for_you_score || 0) > -9999)
            .sort((a, b) => {
              const af = Number(a.for_you_score || 0);
              const bf = Number(b.for_you_score || 0);
              if (bf !== af) return bf - af;
              return Number(b.composite_score || 0) - Number(a.composite_score || 0);
            });
        } else if (sortMode === "trending"){
          items = [...(items || [])].sort((a, b) => {
            const ap = Number(a.popularity || 0);
            const bp = Number(b.popularity || 0);
            if (bp !== ap) return bp - ap;
            return Number(b.composite_score || 0) - Number(a.composite_score || 0);
          });
        } else if (sortMode === "trending_weighted"){
          items = [...(items || [])].sort((a, b) => {
            const normPop = (x) => Math.min(Number(x || 0), 100) / 100;
            const normRating = (x) => Math.min(Number(x || 0), 10) / 10;
            const normHits = (x) => Math.min(Number(x || 0), 6) / 6;

            const aTrend =
              (normPop(a.popularity) * 0.45) +
              (normRating(a.vote_average) * 0.35) +
              (normHits(a.provider_hits) * 0.20);

            const bTrend =
              (normPop(b.popularity) * 0.45) +
              (normRating(b.vote_average) * 0.35) +
              (normHits(b.provider_hits) * 0.20);

            if (bTrend !== aTrend) return bTrend - aTrend;
            return Number(b.composite_score || 0) - Number(a.composite_score || 0);
