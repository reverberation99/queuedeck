          parts.push("Trakt");
        }

        if (providerScores.letterboxd !== undefined) {
          sourceBadges.push('<span class="sourceBadge letterboxd">Letterboxd</span>');
          parts.push("Letterboxd");
        }

        if (providerScores.tvmaze_airing !== undefined) {
          sourceBadges.push('<span class="sourceBadge tvmaze">TVMaze</span>');
          parts.push("TVMaze");
