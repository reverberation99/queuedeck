          sourceSummary = parts.join(" + ");
        } else if (parts.length === 1) {
          sourceSummary = parts[0];
        }

        const hotLabel = isSpecialHot ? "HOT" : (isRising ? "RISING" : "");

        const tmdbWhy = breakdownScores.tmdb_trending !== undefined
          ? `<div class="whyKey">TMDb score</div><div class="whyVal">${esc(Number(breakdownScores.tmdb_trending).toFixed(2))}</div>`
          : ``;
        const traktWhy = breakdownScores.trakt_trending !== undefined
          ? `<div class="whyKey">Trakt score</div><div class="whyVal">${esc(Number(breakdownScores.trakt_trending).toFixed(2))}</div>`
          : ``;

        const traktPopularWhy = breakdownScores.trakt_popular !== undefined
