        } else if (sortMode === "newest"){
          items = [...(items || [])].sort((a, b) => {
            const ay = Number(String(a.year || "").trim()) || 0;
            const by = Number(String(b.year || "").trim()) || 0;
            if (by !== ay) return by - ay;
            return Number(b.composite_score || 0) - Number(a.composite_score || 0);
          });
        }
        // recommended = preserve upstream/default ranking
      }

      items = dedupeDiscoverItems(items, append);
      items = Array.isArray(items) ? items.slice(0, discoverLimit) : [];

      if (!Array.isArray(items) || !items.length){
        if (!append){
          discoverGrid.innerHTML = "";
          const hasYearFilter = !!(yearFromNum || yearToNum);
          const msg =
            consensusMode === "strong" && genreMode !== "all" && hasYearFilter
              ? "No strong-consensus items matched this genre and year range yet."
              : consensusMode === "strong" && genreMode !== "all"
              ? "No strong-consensus items matched this genre yet."
              : consensusMode === "strong" && hasYearFilter
              ? "No strong-consensus items matched this year range yet."
              : consensusMode === "strong"
              ? "No strong-consensus items matched this filter yet."
              : consensusMode === "consensus" && genreMode !== "all" && hasYearFilter
              ? "No consensus items matched this genre and year range yet."
              : consensusMode === "consensus" && genreMode !== "all"
              ? "No consensus items matched this genre yet."
              : consensusMode === "consensus" && hasYearFilter
              ? "No consensus items matched this year range yet."
              : genreMode !== "all" && hasYearFilter
              ? "No items matched this genre and year range yet."
              : consensusMode === "consensus"
              ? "No consensus items matched this filter yet."
              : genreMode !== "all"
              ? "No items matched this genre yet."
              : hasYearFilter
              ? "No items matched this year range yet."
              : "Nothing returned for this source yet.";
          setStatus(msg, "");
        } else {
