            discoverLoadMoreBtn.style.display = "none";
            discoverLoadMoreBtn.disabled = false;
            discoverLoadMoreBtn.textContent = "Load More";
          }
          setStatus("No more results to load.", "");
        }
        return;
      }

      const rendered = items.map(item => {
        const title = esc(item.title || "");
        const year = esc(item.year || "");
        const media = String(item.media_type || "").toUpperCase();
        const scoreSourceLabel = (() => {
          const providerScores = item.provider_scores || {};
          if (providerScores.tmdb_trending !== undefined || providerScores.tmdb_popular !== undefined) return "TMDb";
          if (providerScores.anilist_anime !== undefined) return "AniList";
          if (providerScores.jikan_anime_hot !== undefined || providerScores.jikan_anime_rising !== undefined) return "Jikan";
          if (providerScores.letterboxd !== undefined) return "Letterboxd";
          return "Score";
        })();

        const score = (typeof item.vote_average === "number")
          ? `${scoreSourceLabel} ${ratingDot(item.vote_average)} ${Number(item.vote_average).toFixed(1)}`
