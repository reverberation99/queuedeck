<script>
(function(){
  const refreshBtn = document.getElementById("refreshUserAnimeSafetyBtn");
  const listBox = document.getElementById("userAnimeSafetyList");
  const status = document.getElementById("userAnimeSafetyStatus");

  if (!refreshBtn || !listBox) return;

  function setStatus(msg){
    if (status) status.textContent = msg || "";
  }

  function esc(s){
    return String(s || "")
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#39;");
  }

  async function saveUser(username, enabled, statusNode){
    try{
      const r = await fetch("/api/discover/admin-user-nsfw-anime", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        cache: "no-store",
        body: JSON.stringify({
          user: username,
          hide_nsfw_anime: !!enabled
        })
      });

      const j = await r.json().catch(() => ({}));
      if (!r.ok || !j.ok){
        throw new Error(j.error || "save_failed");
      }

      if (statusNode) statusNode.textContent = "Saved";
      setStatus("Saved.");
    }catch(e){
      console.error(e);
      if (statusNode) statusNode.textContent = "Save failed";
      setStatus("Save failed.");
    }
  }

  function renderUsers(users){
    if (!Array.isArray(users) || !users.length){
      listBox.innerHTML = '<div style="opacity:.7; font-size:13px;">No users found.</div>';
      return;
    }

    listBox.innerHTML = users.map(u => `
      <div style="display:grid; grid-template-columns:minmax(160px, 220px) 1fr auto; gap:12px; align-items:center; padding:10px 12px; border:1px solid rgba(255,255,255,.08); border-radius:12px; background:rgba(255,255,255,.02);">
        <div>
          <div style="font-weight:700;">${esc(u.username)}</div>
          <div style="font-size:12px; opacity:.68;">${u.is_admin ? "Admin" : "User"}</div>
        </div>
        <label style="display:flex; align-items:center; gap:10px; margin:0;">
          <input type="checkbox" data-nsfw-user="${esc(u.username)}" ${u.hide_nsfw_anime ? "checked" : ""} />
          <span>Hide NSFW anime</span>
        </label>
        <span data-nsfw-user-status="${esc(u.username)}" style="font-size:12px; opacity:.72;"></span>
      </div>
    `).join("");

    listBox.querySelectorAll("[data-nsfw-user]").forEach(cb => {
      cb.addEventListener("change", async () => {
        const username = String(cb.getAttribute("data-nsfw-user") || "");
        const rowStatus = cb.closest("div").querySelector("[data-nsfw-user-status]");
        if (rowStatus) rowStatus.textContent = "Saving...";
        cb.disabled = true;
        await saveUser(username, cb.checked, rowStatus);
        cb.disabled = false;
      });
    });
  }

  async function loadUsers(){
    refreshBtn.disabled = true;
    setStatus("Loading users...");
    try{
      const r = await fetch("/api/discover/admin-user-nsfw-anime/list", {
        cache: "no-store"
      });
      const j = await r.json().catch(() => ({}));
      if (!r.ok || !j.ok || !Array.isArray(j.users)){
        throw new Error(j.error || "load_failed");
      }

      renderUsers(j.users);
      setStatus("Loaded.");
    }catch(e){
      console.error(e);
      listBox.innerHTML = '<div style="opacity:.7; font-size:13px;">Failed to load users.</div>';
      setStatus("Load failed.");
    }finally{
      refreshBtn.disabled = false;
    }
  }

  refreshBtn.addEventListener("click", loadUsers);
  loadUsers();
})();
</script>

