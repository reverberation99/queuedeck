    <script>
      function formatAdminDurationFromIso(iso){
        const s = String(iso || "").trim();
        if (!s) return "--";
        const started = new Date(s);
        if (Number.isNaN(started.getTime())) return s;

        let diff = Math.max(0, Date.now() - started.getTime());
        const sec = Math.floor(diff / 1000);
        const days = Math.floor(sec / 86400);
        const hours = Math.floor((sec % 86400) / 3600);
        const mins = Math.floor((sec % 3600) / 60);

        if (days > 0) return `${days}d ${hours}h ${mins}m`;
        if (hours > 0) return `${hours}h ${mins}m`;
        return `${mins}m`;
      }

      function adminPrettyState(status, running){
        const s = String(status || "").trim();
        if (s) return s;
        return running ? "running" : "stopped";
      }

      function adminPrettyHealth(healthStatus){
        const s = String(healthStatus || "").trim();
        return s || "n/a";
      }

      function formatAdminBytes(bytes){
        const n = Number(bytes || 0);
        if (!Number.isFinite(n) || n <= 0) return "0 B";
        const units = ["B", "KB", "MB", "GB", "TB", "PB"];
        let v = n;
        let i = 0;
        while (v >= 1024 && i < units.length - 1){
          v /= 1024;
          i += 1;
        }
        return `${v.toFixed(v >= 100 ? 0 : v >= 10 ? 1 : 2)} ${units[i]}`;
      }

      async function loadAdminSystemUsage(){
        const cpuText = document.getElementById("adminCpuText");
        const memText = document.getElementById("adminMemText");
        const diskText = document.getElementById("adminDiskText");
        const cpuBar = document.getElementById("adminCpuBar");
        const memBar = document.getElementById("adminMemBar");
        const diskBar = document.getElementById("adminDiskBar");
        const status = document.getElementById("adminSystemUsageStatus");
        const btn = document.getElementById("refreshAdminSystemUsageBtn");
        const help = document.getElementById("adminSystemUsageHelp");

        const containerName = document.getElementById("adminContainerName");
        const containerState = document.getElementById("adminContainerState");
        const containerHealth = document.getElementById("adminContainerHealth");
        const containerRestarts = document.getElementById("adminContainerRestarts");
        const containerImage = document.getElementById("adminContainerImage");
        const containerUptime = document.getElementById("adminContainerUptime");

        if (!cpuText || !memText || !diskText || !cpuBar || !memBar || !diskBar) return;

        if (btn) btn.disabled = true;
        if (help){
          help.style.display = "none";
          help.textContent = "";
        }
        if (status) status.textContent = "Loading...";

        try{
          const r = await fetch("/api/admin/system-usage", { cache: "no-store", credentials: "same-origin" });
          const j = await r.json().catch(() => ({}));

          if (!r.ok || !j.ok){
            throw new Error(j.error || ("HTTP " + r.status));
          }

          const cpu = Number(j.cpu_percent || 0);
          const memUsed = Number(j.mem_used || 0);
          const memLimit = Number(j.mem_limit || 0);
          const memPct = Number(j.mem_percent || 0);
          const sizeRw = Number(j.size_rw || 0);
          const sizeRootFs = Number(j.size_root_fs || 0);
          const appSize = Number(j.app_size || 0);
          const dataSize = Number(j.data_size || 0);

          cpuText.textContent = `${cpu.toFixed(2)}%`;
          memText.textContent = `${formatAdminBytes(memUsed)} / ${formatAdminBytes(memLimit)} (${memPct.toFixed(2)}%)`;

          const storageParts = [];
          storageParts.push(`RW ${formatAdminBytes(sizeRw)}`);
          if (sizeRootFs > 0) storageParts.push(`RootFS ${formatAdminBytes(sizeRootFs)}`);
          if (appSize > 0) storageParts.push(`/app ${formatAdminBytes(appSize)}`);
          if (dataSize > 0) storageParts.push(`/data ${formatAdminBytes(dataSize)}`);
          diskText.textContent = storageParts.join(" • ");

          cpuBar.style.width = `${Math.max(0, Math.min(100, cpu))}%`;
          memBar.style.width = `${Math.max(0, Math.min(100, memPct))}%`;

          let storagePct = 0;
          if (sizeRootFs > 0 && sizeRw > 0){
            storagePct = (sizeRw / sizeRootFs) * 100;
          }
          diskBar.style.width = `${Math.max(0, Math.min(100, storagePct))}%`;

          if (containerName) containerName.textContent = j.container_name || j.container_id || "--";
          if (containerState) containerState.textContent = adminPrettyState(j.status, j.running);
          if (containerHealth) containerHealth.textContent = adminPrettyHealth(j.health_status);
          if (containerRestarts) containerRestarts.textContent = String(j.restart_count ?? "--");
          if (containerImage) containerImage.textContent = j.image || "--";

          if (containerUptime){
            if (j.started_at){
              containerUptime.textContent = `Up for ${formatAdminDurationFromIso(j.started_at)}`;
            } else if (j.finished_at){
              containerUptime.textContent = `Last stopped: ${j.finished_at}`;
            } else {
              containerUptime.textContent = "--";
            }
          }

          if (help){
            help.style.display = "none";
            help.textContent = "";
          }
          if (status) status.textContent = `Updated ${new Date().toLocaleTimeString()}.`;
        }catch(e){
          if (help){
            help.style.display = "";
            if (String(e.message || e).includes("docker_socket_not_mounted")){
              help.textContent = "Container stats unavailable. Add /var/run/docker.sock:/var/run/docker.sock:ro to the queuedeck-dev service volumes in docker-compose.yml, then restart QueueDeck.";
            } else {
              help.textContent = "Container stats are temporarily unavailable. Try Refresh Usage in a moment.";
            }
          }
          if (status) status.textContent = `Load failed: ${e.message || e}`;
        }finally{
          if (btn) btn.disabled = false;
        }
      }

