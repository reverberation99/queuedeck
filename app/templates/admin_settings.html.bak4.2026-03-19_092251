      async function pollDiscoverWarmUntilDone(){
        let tries = 0;
        const maxTries = 240; // 4 minutes

        while (tries < maxTries){
          tries += 1;

          let j = {};
          try{
            const r = await fetch("/api/discover/warm-status", {
              cache: "no-store",
              credentials: "same-origin"
            });
            j = await r.json().catch(() => ({}));
          }catch(e){
            setStatus("Saved, but Discover status check failed.", "warn");
            setDiscoverWarmUi("Saved, but Discover status check failed.", 100, true);
            return;
          }

          const total = Math.max(1, Number(j.total || 1));
          const progress = Math.max(0, Number(j.progress || 0));
          const pct = Math.round((progress / total) * 100);
          const msg = String(j.message || "Preparing Discover...").trim();
          const eta = String(j.eta_bucket || "").trim();
          const unresolvedAnimeCount = Number(j.unresolved_anime_count || 0);

          if (j.running){
            const fullMsg = eta ? `${msg} • ${eta}` : msg;
            setStatus(fullMsg, "warn");
            setDiscoverWarmUi(fullMsg, pct, true);
            setDiscoverPrimingStorage(true, fullMsg, pct, eta);
            await new Promise(r => setTimeout(r, 1000));
            continue;
          }

          let readyMsg = "Settings saved. Discover is ready.";
          if (unresolvedAnimeCount > 0){
            readyMsg = `Settings saved. Discover is ready. ${unresolvedAnimeCount} anime titles may benefit from suggestions.`;
          }

          setDiscoverWarmUi(msg || "Discover ready.", 100, true);
          setStatus(readyMsg, "ok");

          setTimeout(() => {
            setDiscoverWarmUi("", 0, false);
          }, 1200);

          return;
        }

        setStatus("Settings saved. Discover is still warming in the background.", "warn");
        setDiscoverWarmUi("Discover is still warming in the background.", 100, true);
      }

