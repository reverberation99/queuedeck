      function normalizeAnimeSuggestionText(s){
        return String(s || "")
          .toLowerCase()
          .replace(/[^a-z0-9]+/g, " ")
          .replace(/\s+/g, " ")
          .trim();
      }

      function stripAnimeSeasonWords(s){
        return normalizeAnimeSuggestionText(s)
          .replace(/\b(final season|season \d+|\d+(st|nd|rd|th) season|part \d+)\b/g, " ")
          .replace(/\s+/g, " ")
          .trim();
      }

      function shouldAutoApplyAnimeSuggestion(originalTitle, overrideTitle){
        const orig = String(originalTitle || "").trim();
        const over = String(overrideTitle || "").trim();
        if (!orig || !over) return false;

        const origNorm = normalizeAnimeSuggestionText(orig);
        const overNorm = normalizeAnimeSuggestionText(over);
        const origBase = stripAnimeSeasonWords(orig);
        const overBase = stripAnimeSeasonWords(over);

        if (!origNorm || !overNorm) return false;

        // Safe: season/part/final-season cleanup that points to the same base title.
        if (origBase && overBase && origBase === overBase) return true;

        // Safe-ish: original contains explicit season/part markers and override is shorter.
        if (
          /(season|part|final season|\b\d+(st|nd|rd|th) season\b)/i.test(orig) &&
          overNorm.length <= origNorm.length
        ){
          return true;
        }

        // Safe-ish: same franchise root / strong token overlap.
        const origTokens = new Set(origBase.split(" ").filter(Boolean));
        const overTokens = new Set(overBase.split(" ").filter(Boolean));
        let overlap = 0;
        for (const t of origTokens){
          if (overTokens.has(t)) overlap += 1;
        }
        if (overlap >= 2 && overTokens.size >= 1) return true;

        return false;
      }

      async function appendAutoAnimeSuggestions(){
        if (!adminDiscoverAnimeEnabled()) return { applied: 0, review: 0 };

        try{
          setStatus("Generating anime title suggestions...", "warn");
          setDiscoverWarmUi("Generating anime title suggestions...", 97, true);
          setDiscoverPrimingStorage(true, "Generating anime title suggestions...", 97, "");

          const r = await fetch("/api/discover/generate-title-overrides", {
            method: "POST",
            credentials: "same-origin"
          });

          const data = await r.json().catch(() => ({}));
          if (!r.ok || !data.ok) return { applied: 0, review: 0 };

          const suggestions = Array.isArray(data.suggestions) ? data.suggestions : [];
          if (!suggestions.length) return { applied: 0, review: 0 };

          const ta = document.getElementById("discover_title_overrides");
          if (!ta) return { applied: 0, review: 0 };

          const existing = String(ta.value || "").trim();
          const existingLines = existing ? existing.split(/\r?\n/).map(x => x.trim()).filter(Boolean) : [];
          const existingSet = new Set(existingLines.map(x => x.toLowerCase()));

          const autoLines = [];
          const reviewLines = [];

          for (const row of suggestions){
            const left = String(row.original_title || "").trim();
            const right = String(row.override_title || "").trim();
            if (!left || !right) continue;

            const line = `${left} | ${right}`;
            if (existingSet.has(line.toLowerCase())) continue;

            if (shouldAutoApplyAnimeSuggestion(left, right)){
              autoLines.push(line);
              existingSet.add(line.toLowerCase());
            } else {
              reviewLines.push(line);
            }
          }

          const merged = [...existingLines, ...autoLines];
          if (reviewLines.length){
            if (merged.length) merged.push("");
            merged.push("# Review these anime suggestions manually:");
            merged.push(...reviewLines);
          }

          ta.value = merged.join("\n");

          if (autoLines.length || reviewLines.length){
            const payload = {};
            for (const id of fields){
              const el = document.getElementById(id);
              if (!el) continue;
              payload[id] = el.value;
            }

            const saveResp = await fetch("/settings/api", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              credentials: "same-origin",
              body: JSON.stringify(payload)
            });

            const saveData = await saveResp.json().catch(() => ({}));
            if (!saveResp.ok || !saveData.ok){
              console.warn("Could not persist auto anime suggestions", saveData);
            }
          }

          return {
            applied: autoLines.length,
            review: reviewLines.length
          };
        }catch(e){
          console.warn("Auto anime suggestions skipped", e);
          return { applied: 0, review: 0 };
        }
      }


      async function primeDiscoverPagesFromAdmin(){
        const jobs = [
          {
            label: "Priming Discover aggregate page 1...",
            url: "/api/discover/items?source=aggregate&media=all&page=1",
            percent: 62
          },
          {
            label: "Priming Discover aggregate page 2...",
            url: "/api/discover/items?source=aggregate&media=all&page=2",
            percent: 74
          }
        ];

        try{
          const feedResp = await fetch("/api/discover/letterboxd-sources", {
            cache: "no-store",
            credentials: "same-origin"
          });

          const feedData = await feedResp.json().catch(() => ({}));
          const feedItems = Array.isArray(feedData.items) ? feedData.items : [];

          for (const item of feedItems){
            const sourceKey = String(item.key || "").trim();
            const label = String(item.label || "Letterboxd Feed").trim() || "Letterboxd Feed";
            if (!sourceKey) continue;

            jobs.push({
              label: `Priming ${label}...`,
              url: `/api/discover/items?source=${encodeURIComponent(sourceKey)}&media=movie&page=1`,
              percent: 82
            });
          }
        }catch(e){
          console.warn("Could not load Letterboxd feed sources for priming", e);
        }

        if (adminDiscoverAnimeEnabled()){
          jobs.push(
            {
              label: "Priming Discover anime page 1...",
              url: "/api/discover/items?source=anime_aggregate&media=tv&page=1",
              percent: 90
            },
            {
              label: "Priming Discover anime page 2...",
              url: "/api/discover/items?source=anime_aggregate&media=tv&page=2",
              percent: 96
            }
          );
        }

        for (const job of jobs){
          await adminPrimeDiscoverRequest(job.label, job.url, job.percent);
        }

        const suggestionResult = await appendAutoAnimeSuggestions();

        let readyText = "Discover primed and ready.";
        if ((suggestionResult.applied || 0) > 0 && (suggestionResult.review || 0) > 0){
          readyText = `Discover primed and ready. Added ${suggestionResult.applied} anime rule(s); ${suggestionResult.review} more need review.`;
        } else if ((suggestionResult.applied || 0) > 0){
          readyText = `Discover primed and ready. Added ${suggestionResult.applied} anime suggestion rule(s).`;
        } else if ((suggestionResult.review || 0) > 0){
          readyText = `Discover primed and ready. ${suggestionResult.review} anime suggestion(s) need review.`;
        }

        setStatus("Settings saved. Discover is ready.", "ok");
        setDiscoverWarmUi(readyText, 100, true);

        setTimeout(() => {
          setDiscoverWarmUi("", 0, false);
        }, 1200);
      }

      async function startDiscoverWarmFromAdmin(){
        setStatus("Preparing Discover data...", "warn");
        setDiscoverWarmUi("Preparing Discover data...", 6, true);
        setDiscoverPrimingStorage(true, "Preparing Discover data...", 6, "");

        try{
          const warmResp = await fetch("/api/discover/warm", {
            method: "POST",
            credentials: "same-origin"
          });

          if (!warmResp.ok){
            const warmErr = await warmResp.text().catch(() => "");
            throw new Error(warmErr || ("HTTP " + warmResp.status));
          }
        }catch(e){
          setStatus("Settings saved, but Discover warm could not be started.", "warn");
          setDiscoverWarmUi("Settings saved, but Discover warm could not be started.", 100, true);
          clearDiscoverPrimingStorage();
          return;
        }

        await pollDiscoverWarmUntilDone();

        try{
          await primeDiscoverPagesFromAdmin();
          clearDiscoverPrimingStorage();
        }catch(e){
          console.error(e);
          setStatus("Settings saved, but Discover priming did not fully complete.", "warn");
          setDiscoverWarmUi("Discover partially primed. First visit may still take a moment.", 100, true);
          clearDiscoverPrimingStorage();

          setTimeout(() => {
            setDiscoverWarmUi("", 0, false);
          }, 1800);
        }
      }


      const sliderFields = [
        "discover_weight_tmdb",
        "discover_weight_tmdb_popular",
        "discover_weight_trakt",
        "discover_weight_trakt_popular",
        "discover_weight_letterboxd",
        "discover_weight_tvmaze",
        "discover_weight_anilist",
        "discover_bonus_2",
        "discover_bonus_3",
        "discover_bonus_4",
        "discover_bonus_5",
        "discover_bonus_6",
        "discover_hot_threshold",
        "discover_enrich_scale",
      ];

      function syncSliderValue(id){
        const input = document.getElementById(id);
        const out = document.getElementById("val_" + id);
        if (!input || !out) return;

        if (id === "discover_enrich_scale"){
          out.textContent = String(input.value || "0");
        } else {
          out.textContent = Number(input.value || 0).toFixed(2);
        }
      }

      function bindSliderValues(){
        sliderFields.forEach(id => {
          const input = document.getElementById(id);
          if (!input) return;
          input.addEventListener("input", () => syncSliderValue(id));
          syncSliderValue(id);
        });
      }

      function parseLetterboxdFeeds(raw){
        return String(raw || "")
          .split(/\r?\n/)
          .map(line => line.trim())
          .filter(Boolean)
          .map(line => {
            const parts = line.split("|");
            if (parts.length >= 2){
              return {
                label: String(parts[0] || "").trim(),
                url: String(parts.slice(1).join("|") || "").trim(),
              };
            }
            return { label: "", url: line };
          });
      }

      function readLetterboxdFeedRows(){
        if (!letterboxdFeedsEditor) return [];
        return [...letterboxdFeedsEditor.querySelectorAll(".feedRow")].map(row => ({
          label: String(row.querySelector('[data-feed-field="label"]')?.value || "").trim(),
          url: String(row.querySelector('[data-feed-field="url"]')?.value || "").trim(),
        }));
      }

      function syncLetterboxdFeedsHiddenField(){
        if (!letterboxdFeedsField) return;
        const rows = readLetterboxdFeedRows()
          .filter(feed => feed.label || feed.url)
          .map(feed => `${feed.label} | ${feed.url}`.trim());
        letterboxdFeedsField.value = rows.join("\n");
        renderLetterboxdFeedsEmptyState();
      }

      function renderLetterboxdFeedsEmptyState(){
        if (!letterboxdFeedsEditor) return;
        const rows = letterboxdFeedsEditor.querySelectorAll(".feedRow");
        const existing = letterboxdFeedsEditor.querySelector(".feedEmpty");

        if (!rows.length){
          if (!existing){
            const empty = document.createElement("div");
            empty.className = "feedEmpty";
            empty.textContent = "No Letterboxd feeds added yet.";
            letterboxdFeedsEditor.appendChild(empty);
          }
        } else if (existing){
          existing.remove();
        }
      }

      function makeLetterboxdFeedRow(feed = {}){
        const row = document.createElement("div");
        row.className = "feedRow";
        row.innerHTML = `
          <input data-feed-field="label" type="text" placeholder="Label" value="${String(feed.label || "").replace(/"/g, '&quot;')}" />
          <input data-feed-field="url" type="text" placeholder="https://letterboxd.com/.../rss/" value="${String(feed.url || "").replace(/"/g, '&quot;')}" />
          <button class="btn secondary" type="button" data-feed-remove="1">Remove</button>
        `;

        row.querySelectorAll("input").forEach(input => {
          input.addEventListener("input", syncLetterboxdFeedsHiddenField);
        });

        row.querySelector('[data-feed-remove="1"]').addEventListener("click", () => {
          row.remove();
          renderLetterboxdFeedsEmptyState();
          syncLetterboxdFeedsHiddenField();
        });

        return row;
      }

      function renderLetterboxdFeedsEditor(){
        if (!letterboxdFeedsEditor || !letterboxdFeedsField) return;

        const rows = parseLetterboxdFeeds(letterboxdFeedsField.value || "");
        letterboxdFeedsEditor.innerHTML = `
          <div class="feedHeader">
            <div>Label</div>
            <div>RSS URL</div>
            <div></div>
          </div>
        `;

        rows.forEach(feed => {
          letterboxdFeedsEditor.appendChild(makeLetterboxdFeedRow(feed));
        });

        renderLetterboxdFeedsEmptyState();
        syncLetterboxdFeedsHiddenField();
      }

      function addLetterboxdFeedRow(feed = {}){
        if (!letterboxdFeedsEditor) return;
        const empty = letterboxdFeedsEditor.querySelector(".feedEmpty");
        if (empty) empty.remove();
        letterboxdFeedsEditor.appendChild(makeLetterboxdFeedRow(feed));
        syncLetterboxdFeedsHiddenField();
      }

      if (addLetterboxdFeedBtn){
        addLetterboxdFeedBtn.addEventListener("click", () => {
          addLetterboxdFeedRow({ label: "", url: "" });
        });
      }

      async function load(){
        try{
          const r = await fetch("/settings/api", { credentials:"same-origin" });
          const data = await r.json();

          fields.forEach(k => {
            const el = document.getElementById(k);
            if (!el) return;

            const incoming = data[k];

            // Important:
            // For fresh installs, many admin app settings may be blank/missing.
            // Do NOT overwrite range inputs with "" because browsers snap them to midpoint (1.00).
            // Let the HTML default value remain in place instead.
            if (incoming === undefined || incoming === null || String(incoming) === "") {
              return;
            }

            el.value = String(incoming);
          });

          renderLetterboxdFeedsEditor();
          bindSliderValues();
          setStatus("Admin settings loaded.", "ok");
          await loadLoginAudit();
        }catch(e){
          console.error(e);
          setStatus("Failed to load admin settings.", "bad");
        }
      }

      async function save(){
        try{
          syncLetterboxdFeedsHiddenField();

          const payload = {};
          fields.forEach(k => {
            const el = document.getElementById(k);
            payload[k] = el ? String(el.value || "").trim() : "";
          });

          const r = await fetch("/settings/api", {
            method:"POST",
            headers:{ "Content-Type":"application/json" },
            credentials:"same-origin",
            body: JSON.stringify(payload)
          });

          const data = await r.json().catch(() => ({}));
          if (!r.ok || !data.ok){
            throw new Error(data.error || ("HTTP " + r.status));
          }

          await startDiscoverWarmFromAdmin();
        }catch(e){
          console.error(e);
          setStatus("Failed to save admin settings.", "bad");
        }
      }

      document.getElementById("saveBtn").addEventListener("click", save);
      document.getElementById("reloadBtn").addEventListener("click", load);

      document.querySelectorAll(".revealBtn").forEach(btn => {
        btn.addEventListener("click", () => {
          const target = document.getElementById(btn.getAttribute("data-reveal-target") || "");
          if (!target) return;
          const isPw = target.type === "password";
          target.type = isPw ? "text" : "password";
          btn.textContent = isPw ? "Hide" : "Show";
        });
      });

      (function(){
        const menu = document.getElementById("userMenu");
        const btn = document.getElementById("userMenuBtn");
        if (!menu || !btn) return;

        function closeMenu(){
          menu.classList.remove("open");
          btn.setAttribute("aria-expanded", "false");
        }

        function openMenu(){
          menu.classList.add("open");
          btn.setAttribute("aria-expanded", "true");
        }

        btn.addEventListener("click", (e) => {
          e.preventDefault();
          e.stopPropagation();
          menu.classList.contains("open") ? closeMenu() : openMenu();
        });

        document.addEventListener("click", (e) => {
          if (!menu.contains(e.target)) closeMenu();
        });

        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape") closeMenu();
        });
      })();

      const refreshAdminSystemUsageBtn = document.getElementById("refreshAdminSystemUsageBtn");
      if (refreshAdminSystemUsageBtn){
        refreshAdminSystemUsageBtn.addEventListener("click", loadAdminSystemUsage);
      }
      loadAdminSystemUsage();
      setInterval(loadAdminSystemUsage, 5000);

      load();
    </script>
  
<script>
(function(){
  const btn = document.getElementById("generateDiscoverOverridesBtn");
  const status = document.getElementById("generateDiscoverOverridesStatus");
  const ta = document.getElementById("discover_title_overrides");
  if (!btn || !ta) return;

  btn.addEventListener("click", async () => {
    btn.disabled = true;
    if (status) status.textContent = "Generating suggestions...";
    try{
      const r = await fetch("/api/discover/generate-title-overrides", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        cache: "no-store"
      });
      const data = await r.json();
      if (!r.ok || !data.ok){
        throw new Error(data.error || "generation_failed");
      }

      const suggestions = Array.isArray(data.suggestions) ? data.suggestions : [];
      if (!suggestions.length){
        if (status) status.textContent = "No suggestions found right now.";
        return;
      }

      const existing = (ta.value || "").trim();
      const append = suggestions.join("\n");
      ta.value = existing ? (existing + "\n" + append) : append;
      if (status) status.textContent = `Added ${suggestions.length} suggestion(s). Review and click Save.`;
    }catch(e){
      if (status) status.textContent = "Generate failed.";
      console.error(e);
    }finally{
      btn.disabled = false;
    }
  });
})();
</script>


